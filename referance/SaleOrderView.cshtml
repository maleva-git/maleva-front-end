                                    <input class="btn btn-warning" type="button" value="Filter" id='btnopenFilter' style="font-weight:bold; font-family:Verdana;color:#313639;font-size:15px;" />
                                </div>
                            </div>



                            <div class="row" style="margin-top:5px;">
                                <div class="col-sm-4" style="color:forestgreen;font-weight:bold;font-size:large;">
                                    <div class="form-inline" style="top: 10px;position: relative;">
                                        <div class="col-sm-6 padding2px">
                                            Total Amt :
                                        </div>
                                        <div class="col-sm-6 padding2px">
                                            <label id="lblviewamt">99.99.999.00</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-2" style="color:forestgreen;font-weight:bold;font-size:large;">
                                    <div class="form-inline" style="position: relative;">
                                        <div class="col-sm-8 padding2px">
                                            Total Count :
                                        </div>
                                        <div class="col-sm-4 padding2px">
                                            <label id="lblviewCount">0</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Filter Window -->
                            <div id="filterWindow" style="display:none">
                                <div>Custom Filter</div>
                                <div style="padding:10px;">
                                    <div style="margin-bottom:10px;">
                                        <div>Select Column:</div>
                                        <div id="columnDropdown"></div>
                                    </div>
                                    <div style="margin-bottom:10px;">
                                        <div>Enter Value:</div>
                                        <input type="text" id="filterValue" style="width: 95%; height: 25px;" />
                                    </div>
                                    <div style="text-align:right; margin-top:10px;">
                                        <input type="button" id="applyFilter" value="Apply Filter" />
                                    </div>
                                </div>
                            </div>

                            @*       <div class="col-sm-11">


        </div>*@
