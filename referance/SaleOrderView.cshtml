                                <div class="row" style="padding-top:68%">
                                    <div class="col" style="padding-left:18.5%;width:125px;">
                                        <input style="font-weight:bold;" type="password" id="txtEditpassword" autofocus />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="Statuswindow" style="display: none">
                            <div>Job Status</div>
                            <div style="overflow: hidden;" id="windowContentS">
                                <div id="gridStatus" style="margin-top:1px">
                                </div>
                            </div>
                        </div>
                        <div id="Employeelogin" style="display: none">
                            <div>Employee Login</div>
                            <div style="overflow: hidden;" id="windowContent9">
                                <div class="row">
                                    <div class="col">
                                        <div class="form-inline form-horizontal">
                                            <div style="text-align : center; width:48%; padding-right:2px;margin-bottom:5px;">
                                                <label id="lblEmployee">EmployeeName</label>
                                            </div>
                                            <div style="width:48%; padding-right:10px;margin-bottom:5px;">
                                                <div id='cmbEmployeename'></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col">
