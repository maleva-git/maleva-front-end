    <style>
        .card {
            border: none;
            box-shadow: 3px 3px 9px #888888;
        }

        .green {
            color: black\9;
            background-color: #B0BF44;
        }

        .yellow {
            color: black\9;
            background-color: yellow;
        }

        .red {
            color: white;
            background-color: red;
        }

        .control-label {
            font-size: 14px;
            text-align: center;
            font-weight: bold;
        }

        .card-header {
            background-color: darkgrey;
            font-weight: bold;
            color: white;
        }

        .form-control {
            font-size: 14px;
        }

        .form-group {
            /*width:60%;*/
        }

        label {
            padding-right: 40px;
            font-weight: bold;
            color: black;
        }

        #titleheader {
            background-color: darkgrey;
            font-size: 20px;
            color: white;
            text-align: center;
        }

        #block_container {
            display: flex;
            justify-content: flex-start;
        }

        #col-container {
            background-color: white;
            border-radius: 3px 4px;
            height: 100%;
            box-shadow: 3px 3px 9px #888888;
        }

        .padding-0 {
            padding-right: 0;
            padding-left: 0;
        }

        .container-fluid {
            overflow: hidden;
        }
        .newpreview {
            height: 500px;
            width: 800px;
            overflow: scroll;
            display: inline-block;
            margin: 10px;
            @*grid-template-columns: repeat(3, 1fr); /* 3 columns */
            gap: 10px;
            *@
        }

        .preview1 {
            display: inline-block;
            margin: 5px;
            width: 250px;
            height: 250px;
        }
